# ═══════════════════════════════════════════════════════════════
# VE-ONESTOPSHOP ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════
# SECURITY NOTE:
# Variables WITHOUT "NEXT_PUBLIC_" prefix are SERVER-ONLY.
# They NEVER reach the browser. This is how we hide tool URLs.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — NEVER expose this. Used for admin operations only.
# Get from: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Site URL ──────────────────────────────────────────────────
# Used for magic link redirect URLs
# Local: http://localhost:3000   Production: https://ve-tools.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── TOOL URLs (SERVER-ONLY — NO NEXT_PUBLIC_ PREFIX!) ─────────
# These are the REAL deployment URLs that the proxy fetches from.
# The browser NEVER sees these values.
#
# Convention: tool ID "my-tool" → env var TOOL_URL_MY_TOOL
#
# ── LIVE TOOLS ──
# Repo: MohammedNerds/tco-calc-prod
TOOL_URL_TCO_CALC_PROD=https://tco-calc-prod-eight.vercel.app
# Repo: MohammedNerds/tco-calc-test
TOOL_URL_TCO_CALC_TEST=https://tco-calc-test-ten.vercel.app
#
# ── FUTURE TOOLS (uncomment when deployed) ──
# TOOL_URL_REVERSE_TIMELINE=https://ve-timeline.vercel.app
# TOOL_URL_BUSINESS_CASE_BUILDER=https://ve-bcase.vercel.app
# TOOL_URL_COMPETITIVE_INTEL=https://ve-compintel.vercel.app
# TOOL_URL_DEAL_ACCELERATOR=https://ve-dealaccel.vercel.app
# TOOL_URL_ROI_ANALYZER=https://ve-roi.vercel.app

# ── Proxy Secret ──────────────────────────────────────────────
# Shared between ve-tools and each tool deployment.
# Tool middleware validates this header to reject direct browser access.
# Generate with: openssl rand -hex 32
PROXY_SECRET=replace-with-openssl-rand-hex-32-output
